#!/usr/bin/env bash
set -euo pipefail

if [[ $# -ne 3 ]]; then
  echo "atoms-deps-cache: usage: atoms-deps-cache <frontend|backend> install <root>" >&2
  exit 2
fi

SCOPE="$1"
ACTION="$2"
ROOT="$3"

if [[ "${ACTION}" != "install" ]]; then
  echo "atoms-deps-cache: unsupported action: ${ACTION}" >&2
  exit 2
fi

if [[ "${SCOPE}" != "frontend" && "${SCOPE}" != "backend" ]]; then
  echo "atoms-deps-cache: unsupported scope: ${SCOPE}" >&2
  exit 2
fi

if [[ ! -d "${ROOT}" ]]; then
  echo "atoms-deps-cache: root does not exist: ${ROOT}" >&2
  exit 2
fi

STATE_DIR="${ROOT}/.atoms/cache/deps"
STATE_FILE="${STATE_DIR}/${SCOPE}.json"
mkdir -p "${STATE_DIR}"

dependency_hash() {
  local scope="$1"
  local root="$2"
  python3 - "${scope}" "${root}" <<'PY'
import hashlib
import sys
from pathlib import Path

scope = sys.argv[1]
root = Path(sys.argv[2])
files_by_scope = {
    "frontend": ["package.json", "pnpm-lock.yaml", "package-lock.json", "yarn.lock"],
    "backend": ["requirements.txt", "pyproject.toml", "uv.lock"],
}

digest = hashlib.sha256()
for name in files_by_scope[scope]:
    path = root / name
    if not path.is_file():
        continue
    digest.update(name.encode("utf-8"))
    digest.update(b"\0")
    digest.update(path.read_bytes())
    digest.update(b"\0")
print(digest.hexdigest())
PY
}

state_hash() {
  local state_file="$1"
  if [[ ! -f "${state_file}" ]]; then
    return 0
  fi
  python3 - "${state_file}" <<'PY'
import json
import sys
from pathlib import Path

try:
    payload = json.loads(Path(sys.argv[1]).read_text(encoding="utf-8"))
except Exception:
    print("")
else:
    print(payload.get("hash", ""))
PY
}

write_state() {
  local state_file="$1"
  local scope="$2"
  local hash="$3"
  python3 - "${state_file}" "${scope}" "${hash}" <<'PY'
import json
import sys
from pathlib import Path

state_file = Path(sys.argv[1])
payload = {"scope": sys.argv[2], "hash": sys.argv[3]}
state_file.write_text(json.dumps(payload, sort_keys=True) + "\n", encoding="utf-8")
PY
}

HASH="$(dependency_hash "${SCOPE}" "${ROOT}")"
PREVIOUS_HASH="$(state_hash "${STATE_FILE}")"

if [[ "${SCOPE}" == "frontend" ]]; then
  if [[ -d "${ROOT}/node_modules" && "${PREVIOUS_HASH}" == "${HASH}" ]]; then
    echo "atoms-deps-cache: frontend hit hash=${HASH}" >&2
    exit 0
  fi

  echo "atoms-deps-cache: frontend miss hash=${HASH}" >&2
  (cd "${ROOT}" && pnpm install --prefer-offline)
  write_state "${STATE_FILE}" "${SCOPE}" "${HASH}"
  exit 0
fi

VENV_PYTHON="${ROOT}/.venv/bin/python"
if [[ -x "${VENV_PYTHON}" && "${PREVIOUS_HASH}" == "${HASH}" ]]; then
  echo "atoms-deps-cache: backend hit hash=${HASH}" >&2
  exit 0
fi

echo "atoms-deps-cache: backend miss hash=${HASH}" >&2
if [[ ! -x "${VENV_PYTHON}" ]]; then
  (cd "${ROOT}" && uv venv .venv)
fi
if [[ -f "${ROOT}/requirements.txt" ]]; then
  (cd "${ROOT}" && uv pip install -q --python .venv/bin/python -r requirements.txt)
fi
write_state "${STATE_FILE}" "${SCOPE}" "${HASH}"
